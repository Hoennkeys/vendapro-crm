# Copie para .env e ajuste os valores.
# Secrets: lidos no servidor (nunca use prefixo VITE_).

# Obrigatório em produção (mín. 32 caracteres para sessão criptografada)
SESSION_SECRET=dev-secret-change-in-production-min-32-chars!!

# SQLite local (padrão em desenvolvimento)
SQLITE_PATH=data/vendapro.sqlite

# Postgres/Supabase (opcional — substitui SQLite quando definido)
# DATABASE_URL=postgresql://user:pass@localhost:5432/vendapro

# Ative a API + SQLite (Fase 7) — requer SESSION_SECRET
VITE_USE_SERVER_DB=true
USE_SERVER_DB=true
